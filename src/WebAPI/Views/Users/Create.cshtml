@{
    ViewData["Title"] = "Create User";
    Layout = "_Layout";
}

<h2>Create New User</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div class="error">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/users/create">
        <table class="form-table">
            <tr>
                <td><label for="username">Username:</label></td>
                <td>
                    <input type="text" id="username" name="username" value="@ViewBag.Username" required class="short" />
                </td>
            </tr>
            <tr>
                <td><label for="password">Password:</label></td>
                <td>
                    <input type="password" id="password" name="password" required class="short" />
                </td>
            </tr>
            <tr>
                <td><label for="roleId">Role:</label></td>
                <td>
                    <select id="roleId" name="roleId" required class="short">
                        @if (ViewBag.Roles != null)
                        {
                            @foreach (var role in (List<Ravuno.DataStorage.Models.Role>)ViewBag.Roles)
                            {
                                <option value="@role.Id" selected="@(ViewBag.RoleId == role.Id ? "selected" : null)">@role.Name</option>
                            }
                        }
                    </select>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <button type="submit" class="btn-primary">Create User</button>
                </td>
            </tr>
        </table>
    </form>

    <p class="margin-top text-small">
        <strong>Password Requirements:</strong><br />
        - Minimum 8 characters<br />
        - At least one uppercase letter<br />
        - At least one lowercase letter<br />
        - At least one digit<br />
        - At least one special character
    </p>
</div>

<p><a href="/users">Back to User List</a></p>
