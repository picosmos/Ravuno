@model Ravuno.DataStorage.Models.User
@{
    ViewData["Title"] = "Edit User";
    Layout = "_Layout";
}

<h2>Edit User</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div style="background-color: #ff0000; color: #fff; padding: 10px; margin-bottom: 10px; border: 2px solid #000;">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/users/edit/@Model.Id">
        <table style="border: none; background: transparent;">
            <tr>
                <td style="border: none; padding: 5px;"><label for="username">Username:</label></td>
                <td style="border: none; padding: 5px;">
                    <input type="text" id="username" name="username" value="@Model.Username" required style="width: 250px; padding: 3px;" />
                </td>
            </tr>
            <tr>
                <td style="border: none; padding: 5px;"><label for="roleId">Role:</label></td>
                <td style="border: none; padding: 5px;">
                    <select id="roleId" name="roleId" required style="width: 250px; padding: 3px;">
                        @if (ViewBag.Roles != null)
                        {
                            @foreach (var role in (List<Ravuno.DataStorage.Models.Role>)ViewBag.Roles)
                            {
                                <option value="@role.Id" selected="@(Model.RoleId == role.Id ? "selected" : null)">@role.Name</option>
                            }
                        }
                    </select>
                </td>
            </tr>
            <tr>
                <td style="border: none; padding: 5px;" colspan="2">
                    <button type="submit" style="background-color: #c0c0c0; border: 2px outset #fff; padding: 5px 15px; cursor: pointer;">Update User</button>
                </td>
            </tr>
        </table>
    </form>
</div>

<p><a href="/users" style="color: #0000ff; text-decoration: underline;">Back to User List</a></p>
