@model Ravuno.DataStorage.Models.User
@{
    ViewData["Title"] = "Edit User";
    Layout = "_Layout";
}

<h2>Edit User</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div class="error">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/users/edit/@Model.Id">
        <table class="form-table">
            <tr>
                <td><label for="username">Username:</label></td>
                <td>
                    <input type="text" id="username" name="username" value="@Model.Username" required class="short" />
                </td>
            </tr>
            <tr>
                <td><label for="roleId">Role:</label></td>
                <td>
                    <select id="roleId" name="roleId" required class="short">
                        @if (ViewBag.Roles != null)
                        {
                            @foreach (var role in (List<Ravuno.DataStorage.Models.Role>)ViewBag.Roles)
                            {
                                <option value="@role.Id" selected="@(Model.RoleId == role.Id ? "selected" : null)">@role.Name</option>
                            }
                        }
                    </select>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <button type="submit" class="btn-primary">Update User</button>
                </td>
            </tr>
        </table>
    </form>
</div>

<p><a href="/users">Back to User List</a></p>
