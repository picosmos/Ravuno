@model List<Ravuno.DataStorage.Models.Query>
@{
    ViewData["Title"] = "All Users' Queries";
    Layout = "_Layout";
}

<h2>All Users' Queries (Admin View)</h2>

<div class="info">
    <strong>Total Queries:</strong> @Model.Count
</div>

@if (ViewBag.Success != null)
{
    <div style="background-color: #008000; color: #fff; padding: 10px; margin-bottom: 10px; border: 2px solid #000;">
        @ViewBag.Success
    </div>
}

@if (ViewBag.Error != null)
{
    <div style="background-color: #ff0000; color: #fff; padding: 10px; margin-bottom: 10px; border: 2px solid #000;">
        @ViewBag.Error
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div style="padding: 10px;">
        <em>No queries found in the system.</em>
    </div>
}
else
{
    <form method="post" action="/stats/all-queries/reassign">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Title</th>
                    <th>Query</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var query in Model)
                {
                    <tr>
                        <td>@query.Id</td>
                        <td>
                            <select name="userId_@query.Id" style="width: 150px; padding: 3px;">
                                @if (ViewBag.Users != null)
                                {
                                    @foreach (var user in (List<Ravuno.DataStorage.Models.User>)ViewBag.Users)
                                    {
                                        <option value="@user.Id" selected="@(query.UserId == user.Id ? "selected" : null)">@user.Username</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>@query.Title</td>
                        <td style="max-width: 400px;">
                            <div class="query-cell"><code class="language-sql">@query.SqlQuery</code></div>
                        </td>
                        <td>
                            <a href="/stats/view-query/@query.Id" style="margin-right: 10px;">View Results</a>
                            <a href="/calendar/@query.Id">Calendar Feed</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div style="margin-top: 20px;">
            <button type="submit" style="background-color: #c0c0c0; border: 2px outset #fff; padding: 5px 15px; cursor: pointer;">Save Changes</button>
        </div>
    </form>
}

<p style="margin-top: 20px;">
    <a href="/">← Back to Home</a>
</p>
