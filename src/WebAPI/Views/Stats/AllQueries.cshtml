@model List<Ravuno.DataStorage.Models.Query>
@{
    ViewData["Title"] = "All Users' Queries";
    Layout = "_Layout";
}

<h2>All Users' Queries (Admin View)</h2>

<div class="info">
    <strong>Total Queries:</strong> @Model.Count
</div>

@if (ViewBag.Success != null)
{
    <div class="success">
        @ViewBag.Success
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="error">
        @ViewBag.Error
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="container">
        <em>No queries found in the system.</em>
    </div>
}
else
{
    <form method="post" action="/stats/all-queries/reassign">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Title</th>
                    <th>Query</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var query in Model)
                {
                    <tr>
                        <td>@query.Id</td>
                        <td>
                            <select name="userId_@query.Id">
                                @if (ViewBag.Users != null)
                                {
                                    @foreach (var user in (List<Ravuno.DataStorage.Models.User>)ViewBag.Users)
                                    {
                                        <option value="@user.Id" selected="@(query.UserId == user.Id ? "selected" : null)">@user.Username</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>@query.Title</td>
                        <td class="max-width-400">
                            <div class="query-cell"><code class="language-sql">@query.SqlQuery</code></div>
                        </td>
                        <td>
                            <a href="/stats/view-query/@query.Id" class="margin-right">View Results</a>
                            <a href="/calendar/public/@query.PublicId">Calendar Feed</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="margin-top">
            <button type="submit" class="btn-primary">Save Changes</button>
        </div>
    </form>
}

<p class="margin-top">
    <a href="/">← Back to Home</a>
</p>
