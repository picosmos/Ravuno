@model List<Ravuno.DataStorage.Models.Query>
@{
    ViewData["Title"] = "My Queries";
    Layout = "_Layout";
}

<h2>My Queries</h2>

<div class="info">
    <a href="/queries/create" class="btn">Create New Query</a>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="container">
        <em>No queries found. <a href="/queries/create">Create your first query</a></em>
    </div>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Query</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var query in Model)
            {
                <tr>
                    <td>@query.Title</td>
                    <td class="max-width-400">
                        <div class="query-cell"><code class="language-sql">@query.SqlQuery</code></div>
                    </td>
                    <td>
                        <a href="/queries/edit/@query.Id" class="margin-right">Edit</a>
                        <a href="/queries/delete/@query.Id" class="text-danger">Delete</a><br />
                        <a href="/stats/view-query/@query.Id" class="margin-right">View Results</a>
                        <a href="/calendar/public/@query.PublicId">Calendar Feed</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
