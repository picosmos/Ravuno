@model List<Ravuno.DataStorage.Models.SqlScript>
@{
    ViewData["Title"] = "My Queries";
    Layout = "_Layout";
}

<h2>My Queries</h2>

<div class="info">
    <a href="/queries/create" style="background-color: #c0c0c0; border: 2px outset #fff; padding: 5px 15px; text-decoration: none; display: inline-block; cursor: pointer;">Create New Query</a>
</div>

@if (Model == null || Model.Count == 0)
{
    <div style="padding: 10px;">
        <em>No queries found. <a href="/queries/create">Create your first query</a></em>
    </div>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Query</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var query in Model)
            {
                <tr>
                    <td>@query.Title</td>
                    <td style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        <code>@query.Query</code>
                    </td>
                    <td>
                        <a href="/queries/edit/@query.Id" style="margin-right: 10px;">Edit</a>
                        <a href="/queries/delete/@query.Id" style="color: #cc0000;">Delete</a><br />
                        <a href="/stats/viewsql/@query.Id" style="margin-right: 10px;">View Results</a>
                        <a href="/calendar/@query.Id">Calendar Feed</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
