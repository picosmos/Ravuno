@model Ravuno.DataStorage.Models.Query
@{
    ViewData["Title"] = "Edit Query";
    Layout = "_Layout";
}

<h2>Edit Query</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div class="error">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/queries/edit/@Model.Id">
        <table class="form-table">
            <tr>
                <td><label for="title">Title:</label></td>
                <td>
                    <input type="text" id="title" name="title" value="@(ViewBag.QueryTitle ?? Model.Title)" required />
                </td>
            </tr>
            <tr>
                <td><label for="query">SQL Query:</label></td>
                <td>
                    <div id="editor-wrapper" style="border: 1px solid #ccc; margin-bottom: 10px;"></div>
                    <textarea id="query" name="query" required style="display: none;">@(ViewBag.QuerySql ?? Model.SqlQuery)</textarea>
                    <button type="button" onclick="testQuery()" class="margin-top">Test Query</button>
                    <span id="test-status"></span>
                    <br />
                    <small class="text-muted">Only SELECT queries are allowed. No INSERT, UPDATE, DELETE, DROP, CREATE, ALTER, TRUNCATE, or EXECUTE statements.</small>
                    
                    <details id="test-results" style="margin-top: 15px;">
                        <summary style="cursor: pointer; font-weight: bold;">Test Results</summary>
                        <div id="results-content" style="margin-top: 10px;"></div>
                    </details>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <button type="submit" class="btn-primary">Save Changes</button>
                    <a href="/queries" class="margin-left">Cancel</a>
                </td>
            </tr>
        </table>
    </form>
</div>

<div class="margin-top">
    <a href="/queries">← Back to Queries</a>
</div>

@section Scripts {
    <script>
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                initializeCodeMirror('editor-wrapper', 'query');
            });
        } else {
            setTimeout(function() {
                initializeCodeMirror('editor-wrapper', 'query');
            }, 0);
        }
    </script>
}
