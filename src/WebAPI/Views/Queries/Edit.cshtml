@model Ravuno.DataStorage.Models.Query
@{
    ViewData["Title"] = "Edit Query";
    Layout = "_Layout";
}

<h2>Edit Query</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div style="background-color: #ff0000; color: #fff; padding: 10px; margin-bottom: 10px; border: 2px solid #000;">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/queries/edit/@Model.Id">
        <table style="border: none; background: transparent;">
            <tr>
                <td style="border: none; padding: 5px; vertical-align: top;"><label for="title">Title:</label></td>
                <td style="border: none; padding: 5px;">
                    <input type="text" id="title" name="title" value="@(ViewBag.Title ?? Model.Title)" required style="width: 500px; padding: 3px;" />
                </td>
            </tr>
            <tr>
                <td style="border: none; padding: 5px; vertical-align: top;"><label for="query">SQL Query:</label></td>
                <td style="border: none; padding: 5px;">
                    <textarea id="query" name="query" required class="sql-editor" oninput="updatePreview(this)">@(ViewBag.Query ?? Model.SqlQuery)</textarea>
                    <br />
                    <details style="margin-top: 5px;">
                        <summary style="cursor: pointer; color: #0000ff;">Show Preview</summary>
                        <pre style="margin-top: 5px; max-height: 200px; overflow: auto;"><code id="query-preview" class="language-sql">@(ViewBag.Query ?? Model.SqlQuery)</code></pre>
                    </details>
                    <small style="color: #666;">Only SELECT queries are allowed. No INSERT, UPDATE, DELETE, DROP, CREATE, ALTER, TRUNCATE, or EXECUTE statements.</small>
                </td>
            </tr>
            <tr>
                <td style="border: none; padding: 5px;" colspan="2">
                    <button type="submit" style="background-color: #c0c0c0; border: 2px outset #fff; padding: 5px 15px; cursor: pointer;">Save Changes</button>
                    <a href="/queries" style="margin-left: 10px;">Cancel</a>
                </td>
            </tr>
        </table>
    </form>
</div>

<div style="margin-top: 20px;">
    <a href="/queries">← Back to Queries</a>
</div>

@section Scripts {
    <script>
        function updatePreview(textarea) {
            var preview = document.getElementById('query-preview');
            if (preview) {
                preview.textContent = textarea.value;
                if (window.Prism) {
                    window.Prism.highlightElement(preview);
                }
            }
        }
        
        // Initial highlight on page load
        document.addEventListener('DOMContentLoaded', function() {
            var textarea = document.getElementById('query');
            if (textarea) {
                updatePreview(textarea);
            }
        });
    </script>
}
