@model Ravuno.DataStorage.Models.Query
@{
    ViewData["Title"] = "Delete Query";
    Layout = "_Layout";
}

<h2>Delete Query</h2>

<div style="background-color: #ff0000; color: #fff; padding: 10px; margin-bottom: 10px; border: 2px solid #000;">
    <strong>Warning:</strong> Are you sure you want to delete this query? This action cannot be undone.
</div>

<div class="container">
    <table style="border: none; background: transparent;">
        <tr>
            <td style="border: none; padding: 5px; font-weight: bold;">Title:</td>
            <td style="border: none; padding: 5px;">@Model.Title</td>
        </tr>
        <tr>
            <td style="border: none; padding: 5px; vertical-align: top; font-weight: bold;">Query:</td>
            <td style="border: none; padding: 5px;">
                <pre style="background: #f0f0f0; padding: 10px; overflow-x: auto;">@Model.SqlQuery</pre>
            </td>
        </tr>
    </table>

    <form method="post" action="/queries/delete/@Model.Id" style="margin-top: 20px;">
        <button type="submit" style="background-color: #cc0000; color: #fff; border: 2px outset #fff; padding: 5px 15px; cursor: pointer;">Confirm Delete</button>
        <a href="/queries" style="margin-left: 10px;">Cancel</a>
    </form>
</div>

<div style="margin-top: 20px;">
    <a href="/queries">← Back to Queries</a>
</div>
