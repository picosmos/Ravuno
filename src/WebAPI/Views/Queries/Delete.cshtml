@model Ravuno.DataStorage.Models.Query
@{
    ViewData["Title"] = "Delete Query";
    Layout = "_Layout";
}

<h2>Delete Query</h2>

<div class="warning">
    <strong>Warning:</strong> Are you sure you want to delete this query? This action cannot be undone.
</div>

<div class="container">
    <table class="form-table">
        <tr>
            <td><strong>Title:</strong></td>
            <td>@Model.Title</td>
        </tr>
        <tr>
            <td><strong>Query:</strong></td>
            <td>
                <pre>@Model.SqlQuery</pre>
            </td>
        </tr>
    </table>

    <form method="post" action="/queries/delete/@Model.Id" class="margin-top">
        <button type="submit" class="btn-delete">Confirm Delete</button>
        <a href="/queries" class="margin-left">Cancel</a>
    </form>
</div>

<div class="margin-top">
    <a href="/queries">← Back to Queries</a>
</div>
