<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ravuno Stats</title>
    <style>
        body {
            font-family: "Courier New", monospace;
            background-color: #c0c0c0;
            margin: 0;
            padding: 20px;
            color: #000;
        }
        
        h1 {
            background-color: #000080;
            color: #fff;
            padding: 10px;
            margin: 0 0 20px 0;
            border: 2px outset #fff;
        }
        
        h2 {
            background-color: #008080;
            color: #fff;
            padding: 8px;
            margin: 20px 0 10px 0;
            border: 2px outset #fff;
        }
        
        .container {
            background-color: #fff;
            padding: 20px;
            border: 2px inset #808080;
            margin-bottom: 20px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            border: 2px solid #000;
            background-color: #fff;
        }
        
        th {
            background-color: #000080;
            color: #fff;
            padding: 8px;
            text-align: left;
            border: 1px solid #000;
            font-weight: bold;
        }
        
        td {
            padding: 8px;
            border: 1px solid #808080;
        }
        
        tr:nth-child(even) {
            background-color: #e0e0e0;
        }
        
        tr:nth-child(odd) {
            background-color: #f0f0f0;
        }
        
        .pagination {
            margin-top: 20px;
            padding: 10px;
            background-color: #c0c0c0;
            border: 2px outset #fff;
        }
        
        .pagination a,
        .pagination span {
            padding: 5px 10px;
            margin: 0 2px;
            background-color: #c0c0c0;
            border: 2px outset #fff;
            text-decoration: none;
            color: #000;
            display: inline-block;
        }
        
        .pagination a:hover {
            background-color: #808080;
            color: #fff;
        }
        
        .pagination .current {
            background-color: #000080;
            color: #fff;
            border: 2px inset #808080;
        }
        
        .nav {
            margin-bottom: 20px;
            padding: 10px;
            background-color: #808080;
            border: 2px outset #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .nav-links {
            display: flex;
            gap: 5px;
        }
        
        .nav a {
            color: #fff;
            text-decoration: none;
            padding: 5px 15px;
            background-color: #000080;
            border: 2px outset #fff;
            display: inline-block;
        }
        
        .nav a:visited {
            color: #fff;
        }
        
        .nav a:hover {
            background-color: #0000ff;
        }
        
        .user-info {
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .user-info button {
            background-color: #c0c0c0;
            border: 2px outset #fff;
            padding: 2px 8px;
            cursor: pointer;
        }
        
        pre {
            background-color: #fff;
            padding: 15px;
            border: 2px inset #808080;
            overflow-x: auto;
            font-family: "Courier New", monospace;
        }
        
        .info {
            padding: 10px;
            background-color: #ffff00;
            border: 2px solid #000;
            margin-bottom: 10px;
        }
        
        code {
            background-color: #fff;
            padding: 2px 6px;
            border: 1px solid #808080;
            font-family: "Courier New", monospace;
        }
        
        a {
            color: #0000ff;
            text-decoration: underline;
        }
        
        a:visited {
            color: #800080;
        }
        
        a:hover {
            color: #ff00ff;
        }
    </style>
</head>
<body>
    <h1>Ravuno Statistics Portal</h1>
    
    <div class="nav">
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/stats/items">All Items</a>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="user-info">
                <span>Logged in as: <strong>@User.Identity?.Name</strong> (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                <form method="post" action="/logout" style="display: inline;">
                    <button type="submit">Logout</button>
                </form>
            </div>
        }
    </div>
    
    <div class="container">
        @RenderBody()
    </div>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
