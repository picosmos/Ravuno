<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ravuno Stats</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/codemirror.min.css" />
</head>
<body>
    <h1>Ravuno Statistics Portal</h1>
    
    <div class="nav">
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/queries">My Queries</a>
            <a href="/stats/items">All Items</a>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="user-info">
                <span>Logged in as: <strong>@User.Identity?.Name</strong> (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                <a href="/users/change-password" class="btn-link">Change Password</a>
                <form method="post" action="/logout">
                    <button type="submit">Logout</button>
                </form>
            </div>
        }
    </div>
    
    <div class="container">
        @RenderBody()
    </div>
    
    <script src="/js/codemirror.min.js"></script>
    <script src="/js/codemirror-sql.min.js"></script>
    <script src="/js/query.js"></script>
    <script src="/js/codemirror-highlight.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
