@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<h2>Login</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div class="error">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/login?returnUrl=@ViewBag.ReturnUrl">
        <table class="form-table">
            <tr>
                <td><label for="username">Username:</label></td>
                <td>
                    <input type="text" id="username" name="username" required autofocus class="short" />
                </td>
            </tr>
            <tr>
                <td><label for="password">Password:</label></td>
                <td>
                    <input type="password" id="password" name="password" required class="short" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <button type="submit" class="btn-primary">Login</button>
                </td>
            </tr>
        </table>
    </form>

    <p class="margin-top text-small">
        <em>Default credentials: username "admin", password "password"</em>
    </p>
</div>
