@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<h2>Login</h2>

<div class="container">
    @if (ViewBag.Error != null)
    {
        <div style="background-color: #ff0000; color: #fff; padding: 10px; margin-bottom: 10px; border: 2px solid #000;">
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/login?returnUrl=@ViewBag.ReturnUrl">
        <table style="border: none; background: transparent;">
            <tr>
                <td style="border: none; padding: 5px;"><label for="username">Username:</label></td>
                <td style="border: none; padding: 5px;">
                    <input type="text" id="username" name="username" required autofocus style="width: 250px; padding: 3px;" />
                </td>
            </tr>
            <tr>
                <td style="border: none; padding: 5px;"><label for="password">Password:</label></td>
                <td style="border: none; padding: 5px;">
                    <input type="password" id="password" name="password" required style="width: 250px; padding: 3px;" />
                </td>
            </tr>
            <tr>
                <td style="border: none; padding: 5px;" colspan="2">
                    <button type="submit" style="background-color: #c0c0c0; border: 2px outset #fff; padding: 5px 15px; cursor: pointer;">Login</button>
                </td>
            </tr>
        </table>
    </form>

    <p style="margin-top: 20px; font-size: 0.9em;">
        <em>Default credentials: username "admin", password "password"</em>
    </p>
</div>
